{
  "redirects": [
    {
      "source": "/nationaldex.html",
      "destination": "/nationaldex",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/datadex/adm",
      "destination": "/datadex_adm.html"
    },
    {
      "source": "/datadex/nationaldex/:slug*",
      "destination": "/nationaldex.html"
    },
    {
      "source": "/datadex",
      "destination": "/datadex.html"
    },
    {
      "source": "/datadex/",
      "destination": "/datadex.html"
    },
    {
      "source": "/nationaldex/adm",
      "destination": "/nationaldex_adm.html"
    },
    {
      "source": "/nationaldex/:slug*",
      "destination": "/nationaldex.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
