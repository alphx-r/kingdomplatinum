{
  "redirects": [
    { "source": "/nationaldex.html", "destination": "/nationaldex", "permanent": true }
  ],
  "rewrites": [
    { "source": "/datadex/adm",              "destination": "/datadex_adm.html"  },
    { "source": "/datadex/nationaldex/:slug*","destination": "/nationaldex.html" },
    { "source": "/datadex",                  "destination": "/datadex.html"      },
    { "source": "/datadex/",                 "destination": "/datadex.html"      },
    { "source": "/nationaldex/adm",          "destination": "/nationaldex_adm.html" },
    { "source": "/nationaldex/:slug*",       "destination": "/nationaldex.html"  },
    { "source": "/pokemon.json",             "destination": "/pokemon.json"      },
    { "source": "/api/cron/backup-pokemon",  "destination": "/api/cron/backup-pokemon" },
    { "source": "/(.*)",                     "destination": "/index.html"        }
  ],
  "headers": [
    {
      "source": "/pokemon.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/backup-pokemon", "schedule": "0 9 * * *" }
  ]
}
